load("@rules_cc//cc:defs.bzl", "cc_library")
load("@rules_rust//rust:defs.bzl", "rust_library")

# Compatibility shim: the fizz-rs FFI sources #define GLOG_USE_GLOG_EXPORT
# (for CMake-based glog), which triggers #include "glog/export.h". The
# glog Bazel build on BCR doesn't generate that header, so we provide a stub.
cc_library(
    name = "glog_compat",
    hdrs = ["compat/glog/export.h"],
    strip_include_prefix = "compat",
)

# Pre-generated CXX bridge header (accessible as fizz_rs/src/bridge.rs.h).
# Generated with: cxxbridge third_party/fizz-rs/src/bridge.rs --header
cc_library(
    name = "fizz_rs_bridge_include",
    hdrs = ["generated/bridge.rs.h"],
    strip_include_prefix = "generated",
    include_prefix = "fizz_rs/src",
)

# Pre-generated CXX bridge source.
# Generated with: cxxbridge third_party/fizz-rs/src/bridge.rs
cc_library(
    name = "fizz_rs_bridge",
    srcs = ["generated/bridge.rs.cc"],
    linkstatic = True,
    deps = [
        ":fizz_rs_bridge_include",
        ":fizz_rs_ffi_hdrs",
        ":glog_compat",
        "@crates//:cxx_cc",
    ],
)

# FFI header files (exposed as ffi/*.h).
cc_library(
    name = "fizz_rs_ffi_hdrs",
    hdrs = glob(["fizz-rs/src/ffi/*.h"]),
    strip_include_prefix = "fizz-rs/src",
    copts = ["-std=c++17"],
    deps = [
        ":glog_compat",
        "@crates//:cxx_cc",
        "@fizz",
    ],
)

# C++ FFI implementation — the critical BCR fizz compatibility test.
cc_library(
    name = "fizz_rs_ffi",
    srcs = glob(["fizz-rs/src/ffi/*.cpp"]),
    copts = ["-std=c++17"],
    linkstatic = True,
    deps = [
        ":fizz_rs_bridge",
        ":fizz_rs_bridge_include",
        ":fizz_rs_ffi_hdrs",
        ":glog_compat",
        "@crates//:cxx_cc",
        "@fizz",
    ],
)

# Rust library wrapping the C++ FFI.
rust_library(
    name = "fizz_rs",
    srcs = glob(["fizz-rs/src/**/*.rs"]),
    crate_root = "fizz-rs/src/lib.rs",
    crate_name = "fizz_rs",
    edition = "2021",
    deps = [
        ":fizz_rs_bridge",
        ":fizz_rs_ffi",
        "@crates//:bytes",
        "@crates//:cxx",
        "@crates//:serde",
        "@crates//:thiserror",
        "@crates//:tokio",
    ],
    visibility = ["//visibility:public"],
)
